export AWS_REGION="us-east-1"
export AWS_IOT_DATA_ENDPOINT="your-account-prefix-ats.iot.us-east-1.amazonaws.com"
export AWS_IOT_TOPIC="detections"
export AWS_S3_BUCKET="your-detection-bucket"
export AWS_S3_PREFIX="detections"
export MIN_DETECTION_CONFIDENCE="0.70"

# Option 1: use standard AWS SDK environment variables
export AWS_ACCESS_KEY_ID="YOUR_ACCESS_KEY_ID"
export AWS_SECRET_ACCESS_KEY="YOUR_SECRET_ACCESS_KEY"

# Optional: only if you are using temporary credentials
# export AWS_SESSION_TOKEN="YOUR_SESSION_TOKEN"

# Optional: override the local backup directory
# export DETECTION_BACKUP_DIR="/home/pi/detection-backups"
